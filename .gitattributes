# Normalize line endings: store LF in the repo, let git handle the working tree.
# Prevents CRLF churn on Windows/WSL checkouts that otherwise floods diffs.
* text=auto eol=lf

# Binary types — never normalize.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.pdf binary
*.zip binary
*.gz binary
*.mp4 binary
*.webm binary
