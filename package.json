{
  "name": "@tybrite-labs/sdk",
  "version": "1.0.8",
  "description": "TypeScript SDK for Galactic Core — a headless commerce API for catalog, cart, checkout, orders, payments, customers, search, recommendations, promotions, gift cards, returns and webhooks.",
  "homepage": "https://gc.tybritelabs.com",
  "bugs": {
    "url": "https://docs.tybritelabs.com"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "generate": "openapi --input ../cloudflare-workers/openapi.yaml --output ./src --client fetch --name Tybrite --useOptions && node scripts/post-generate.js",
    "build": "tsc",
    "clean": "rimraf src dist",
    "sync": "node scripts/sync-sdk.js",
    "version:update": "node scripts/version-manager.js",
    "deploy": "node scripts/deploy-sdk.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "headless-commerce",
    "ecommerce",
    "ecommerce-api",
    "commerce",
    "commerce-api",
    "storefront",
    "headless",
    "shopping-cart",
    "checkout",
    "orders",
    "payments",
    "stripe",
    "product-catalog",
    "inventory",
    "promotions",
    "gift-cards",
    "semantic-search",
    "product-recommendations",
    "multi-currency",
    "marketplace",
    "webhooks",
    "rest-api",
    "typescript",
    "sdk",
    "typescript-sdk",
    "openapi",
    "tybrite",
    "galactic-core",
    "tybrite-labs-sdk",
    "galactic-core-sdk",
    "gc-sdk",
    "tybrite-gc-sdk",
    "gc-tybrite-sdk"
  ],
  "author": "Tybrite Labs",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.10.5",
    "openapi-typescript-codegen": "^0.29.0",
    "rimraf": "^6.0.1",
    "tsx": "^4.21.0",
    "typedoc": "^0.28.16",
    "typedoc-plugin-markdown": "^4.10.0",
    "typescript": "^5.7.3"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.57.4",
    "@tybrite-labs/sdk": "^1.0.0"
  }
}
